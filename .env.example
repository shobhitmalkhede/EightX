# ClickUp API Token
# Get yours from: ClickUp > Settings > Apps > API Token
CLICKUP_API_TOKEN=your_clickup_api_token_here

# ClickUp Team (Workspace) ID
# You can find this in the URL when you're in ClickUp: app.clickup.com/{team_id}/...
CLICKUP_TEAM_ID=your_team_id_here

# Server Port (Railway sets this automatically)
PORT=3000
